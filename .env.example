# Copy to `.env` in the project root and set values. Commit only this example file.
#
# Unsplash dashboard (application ID & keys): https://unsplash.com/oauth/applications

# --- Client app (bundled at build time from process.env; keep out of git) ---
# Public Access Key — used as Client-ID for https://unsplash.com/documentation#authorization
#
# Never put the Unsplash Secret Key in `.env` for this mobile app or in source code.
# Secret keys are for server-side OAuth only.

EXPO_PUBLIC_UNSPLASH_ACCESS_KEY=
